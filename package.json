{
  "name": "discord-translator-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node scripts/check-env.mjs && tsx src/index.ts",
    "register:commands": "tsx scripts/register-commands.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
